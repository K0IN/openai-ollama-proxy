# openai-ollama-proxy environment file
#
# Copy to `.env` and edit to taste:   cp .env.example .env
# Compose loads `.env` automatically; the proxy itself does not.
# Never commit `.env` — it's listed in `.gitignore`.

# --- vLLM credentials -----------------------------------------------------
# Required. Shared between vLLM (--api-key) and the proxy
# (Authorization: Bearer ...). Pick something non-trivial even on localhost.
VLLM_API_KEY=change-me

# Required if pulling gated models from Hugging Face Hub.
HF_TOKEN=

# --- Proxy listen / upstream ---------------------------------------------
LISTEN_ADDR=:11434
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL=Qwen3.6
MODEL_NAME=qwen3:latest
MODEL_CONTEXT_LENGTH=65536
OLLAMA_VERSION=0.6.4

# --- Timeouts & limits ----------------------------------------------------
# How long to keep retrying upstream while vLLM is starting.
VLLM_STARTUP_WAIT=30m
VLLM_RETRY_INTERVAL=2s
# Per-request HTTP timeouts.
HTTP_REQUEST_TIMEOUT=30s
HTTP_STREAM_TIMEOUT=5m
# Drain time on SIGTERM/SIGINT.
SHUTDOWN_TIMEOUT=30s
# Max accepted JSON request body size (bytes). 32 MiB by default.
MAX_REQUEST_BYTES=33554432

# --- Misc ----------------------------------------------------------------
# Set to true/1 to dump request bodies and headers (Authorization redacted).
DEBUG=false

# vLLM CUDA tunable, leave default unless you know you need it.
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
